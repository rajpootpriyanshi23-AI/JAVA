Area of Rectangle

public class AreaOfRectangle {
    public static void main(String[] args) {

        int length = 10;
        int breadth = 5;

        int area = length * breadth;

        System.out.println("Length : " + length);
        System.out.println("Breadth: " + breadth);
        System.out.println("Area   : " + area);

    }
}


Length : 10
Breadth: 5
Area   : 50
